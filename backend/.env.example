PORT=5000
DATABASE_URL=postgresql://user:password@host:6543/postgres
ADMIN_API_KEY=change-me-to-a-strong-secret
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin@fpt.edu.vn
ADMIN_SEED_EMAIL=admin@fpt.edu.vn
ADMIN_SEED_PASSWORD=Admin@123456
ADMIN_SEED_NAME=Unimate Admin
CLIENT_ORIGIN=http://localhost:5173

APP_NAME=ChatBox Server
APP_ENV=dev
PUBLIC_BASE_URL=http://localhost:5000
CORS_ALLOW_ORIGINS=*

LLM_PROVIDER=openai
STT_PROVIDER=fpt
TTS_PROVIDER=viettel
CHAT_STORE_PROVIDER=postgres

AUDIO_STORAGE_DIR=storage/audio
VOICE_UPLOAD_DIR=storage/uploads
FFMPEG_PATH=ffmpeg

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1
OPENAI_RECENT_HISTORY_LIMIT=6
OPENAI_MAX_OUTPUT_TOKENS=800
OPENAI_RETRY_MAX_OUTPUT_TOKENS=1400
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_FILE_SEARCH_MAX_RESULTS=8
OPENAI_VECTOR_FILE_POLL_ATTEMPTS=45
OPENAI_VECTOR_FILE_POLL_INTERVAL_SECONDS=2
OPENAI_VECTOR_STORE_ID=
OPENAI_VECTOR_STORE_ID_FILE=storage/openai_vector_store_id.txt
OPENAI_VECTOR_STORE_NAME=fpt-university-regulations

FPT_ASR_URL=https://api.fpt.ai/hmi/asr/general
FPT_ASR_API_KEY=your_fpt_api_key
VIETTEL_TTS_URL=https://viettelai.vn/tts/speech_synthesis
VIETTEL_TTS_TOKEN=your_viettel_tts_token
VIETTEL_TTS_VOICE=hcm-diemmy
VIETTEL_TTS_SPEED=1.0
VIETTEL_TTS_RETURN_OPTION=2
VIETTEL_TTS_WITHOUT_FILTER=false
